---
import BaseLayout from "../../../layouts/BaseLayout.astro";
import Icon from "../../../components/atoms/Icon.astro";
import Cover from "../../../components/atoms/Cover.astro";
import avatarImage from "../../../assets/images/foto-perfil.png";
import ReadingProgress from "../../../components/islands/ReadingProgress";
import {
  loadPostsByLocale,
  loadPostEntry,
  type PostMeta,
} from "../../../content/loadPosts";
import { supportedCodes, defaultLocale, resolveLocale } from "../../../i18n/config";
import { t } from "../../../i18n/translate";

export async function getStaticPaths() {
  const byLocale = await loadPostsByLocale();
  const paths: { params: { lang: string; slug: string } }[] = [];
  for (const lang of supportedCodes) {
    const list = byLocale[lang] ?? [];
    for (const post of list) {
      paths.push({ params: { lang, slug: post.id } });
    }
  }
  return paths;
}

const { lang, slug } = Astro.params;
const langCode = resolveLocale(lang);

const resolved = await loadPostEntry(langCode, slug as string);
if (!resolved) {
  return Astro.redirect(`/${langCode}/`);
}

const { entry } = resolved;
const { Content, headings } = await entry.render();
const h2Headings = headings.filter((h) => h.depth === 2);

const byLocale = await loadPostsByLocale();
const localizedList: PostMeta[] = byLocale[langCode] ?? byLocale[defaultLocale] ?? [];
const morePosts = localizedList
  .filter((p) => p.id !== slug)
  .slice(0, 3);

const post = entry.data;
const displayDate = post.displayDate;
const readMinLabel = t("blog.min_read", undefined, langCode);
---

<BaseLayout
  locale={langCode}
  title={`${post.title} · Diego Cabrera`}
  description={post.excerpt}
>
  <ReadingProgress client:load />

  <div class="post-page">
    <div class="container">
      <div class="post-breadcrumb">
        <a href={`/${langCode}/#blog`} class="back-btn">
          <span class="back-arrow">←</span>
          <span>{t("post.back", undefined, langCode)}</span>
        </a>
        <div class="bc-trail">
          <span class="hide-mobile">diego.cabrera</span>
          <span class="show-mobile">d.c</span>
          <span class="bc-sep">/</span>
          <span>blog</span>
          <span class="bc-sep">/</span>
          <span class="bc-current">{slug}</span>
        </div>
      </div>
    </div>

    <article class="post-hero">
      <div class="container">
        <div class="post-hero-eyebrow">
          <span class="post-cat">{post.category}</span>
          <span class="post-meta-item">{displayDate}</span>
          <span class="post-meta-item">{post.readMin} {readMinLabel}</span>
        </div>
        <h1 class="post-title">{post.title}</h1>
        <p class="post-lede">{post.excerpt}</p>
        <div class="post-tags">
          {(post.tags ?? []).map((tag: string) => <span class="skill-chip">{tag}</span>)}
        </div>
      </div>
      <div class="container">
        <div class="post-cover">
          <Cover kind={post.cover} label={post.category} />
        </div>
      </div>
    </article>

    <div class="container">
      <div class="post-layout">
        <aside class="post-toc">
          <div class="post-toc-inner">
            <div class="toc-title">{t("post.toc.title", undefined, langCode)}</div>
            <ol>
              {h2Headings.map((h) => (
                <li>
                  <a href={`#${h.slug}`}>{h.text}</a>
                </li>
              ))}
            </ol>
            <div class="toc-share">
              <div class="toc-share-title">{t("post.share.title", undefined, langCode)}</div>
              <div class="toc-share-row">
                <button class="toc-share-btn" data-copy-url>
                  {t("post.share.copy", undefined, langCode)}
                </button>
                <a
                  class="toc-share-btn"
                  href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}`}
                  target="_blank"
                  rel="noreferrer">𝕏</a
                >
                <a
                  class="toc-share-btn"
                  href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://diegocabrera.dev/${langCode}/blog/${slug}`)}`}
                  target="_blank"
                  rel="noreferrer">in</a
                >
              </div>
            </div>
          </div>
        </aside>

        <div class="post-main">
          <div class="tldr">
            <h4>{t("post.tldr", undefined, langCode)}</h4>
            <p>{post.excerpt}</p>
          </div>

          <div class="article-body">
            <Content />
          </div>

          <div class="post-author">
            <div class="post-author-avatar">
              <img
                src={avatarImage.src}
                alt={t("post.author.alt", undefined, langCode)}
                class="post-author-photo"
                loading="eager"
              />
            </div>
            <div class="post-author-info">
              <div class="post-author-eyebrow">{t("post.author.eyebrow", undefined, langCode)}</div>
              <div class="post-author-name">Diego Cabrera</div>
              <div class="post-author-role">
                {t("post.author.role", undefined, langCode)}
              </div>
              <div class="post-author-actions">
                <a
                  class="hero-social-btn"
                  href="https://www.linkedin.com/in/diego-andres-rojas/"
                  target="_blank"
                  rel="noreferrer"
                >
                  <Icon name="linkedin" />
                  <span>LinkedIn</span>
                </a>
                <a
                  class="hero-social-btn"
                  href="https://github.com/darcdev"
                  target="_blank"
                  rel="noreferrer"
                >
                  <Icon name="github" />
                  <span>GitHub</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="post-more">
        <div class="eyebrow">
          <span class="idx">→</span> · {t("post.more.eyebrow", undefined, langCode)}
        </div>
        <h3
          class="sect-title"
          style="margin-top: 16px; font-size: clamp(28px, 3.4vw, 40px);"
        >
          {t("post.more.title", undefined, langCode)}
        </h3>
        <div class="mag-bottom" style="margin-top: 36px;">
          {morePosts.map((p) => (
            <a
              href={`/${langCode}/blog/${p.id}`}
              class="mag-card mag-base"
              style="text-decoration: none; color: inherit;"
            >
              <div class="mag-cover">
                <Cover kind={p.cover} label={p.category} />
              </div>
              <div class="mag-body">
                <div class="mag-eyebrow">
                  <span>{p.category}</span>
                  <span>·</span>
                  <span>{p.date}</span>
                </div>
                <h3 class="mag-title">{p.title}</h3>
                <p class="mag-excerpt-short">{p.excerpt}</p>
                <div class="mag-foot">
                  <span class="mag-read">{p.readMin} {readMinLabel} →</span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>

      <div class="post-cta">
        <h3>{t("post.cta.title", undefined, langCode)}</h3>
        <p>{t("post.cta.lede", undefined, langCode)}</p>
        <a href={`/${langCode}/#contact`} class="btn btn-primary">
          {t("post.cta.button", undefined, langCode)}
          <Icon name="arrow" />
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelector("[data-copy-url]")?.addEventListener("click", () => {
    navigator.clipboard?.writeText(window.location.href);
  });
</script>
