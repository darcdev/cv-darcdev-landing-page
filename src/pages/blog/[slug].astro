---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Icon from "../../components/atoms/Icon.astro";
import Cover from "../../components/atoms/Cover.astro";
import avatarImage from "../../assets/images/foto-perfil.png";
import ReadingProgress from "../../components/islands/ReadingProgress";
import { POSTS } from "../../data";
import type { Post } from "../../data/posts";

export function getStaticPaths() {
  return POSTS.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: Post;
}

const { post } = Astro.props;
const headings = post.body.filter((b) => b.type === "h2");
const morePosts = POSTS.filter((p) => p.id !== post.id).slice(0, 3);
---

<BaseLayout title={`${post.title} · Diego Cabrera`} description={post.excerpt}>
  <ReadingProgress client:load />

  <div class="post-page">
    <div class="container">
      <div class="post-breadcrumb">
        <a href="/#blog" class="back-btn">
          <span class="back-arrow">←</span>
          <span>Volver al blog</span>
        </a>
        <div class="bc-trail">
          <span class="hide-mobile">diego.cabrera</span>
          <span class="show-mobile">d.c</span>
          <span class="bc-sep">/</span>
          <span>blog</span>
          <span class="bc-sep">/</span>
          <span class="bc-current">{post.id}</span>
        </div>
      </div>
    </div>

    <article class="post-hero">
      <div class="container">
        <div class="post-hero-eyebrow">
          <span class="post-cat">{post.category}</span>
          <span class="post-meta-item">{post.date}</span>
          <span class="post-meta-item">{post.readMin} min lectura</span>
        </div>
        <h1 class="post-title">{post.title}</h1>
        <p class="post-lede">{post.excerpt}</p>
        <div class="post-tags">
          {post.tags.map((t) => <span class="skill-chip">{t}</span>)}
        </div>
      </div>
      <div class="container">
        <div class="post-cover">
          <Cover kind={post.cover} label={post.category} />
        </div>
      </div>
    </article>

    <div class="container">
      <div class="post-layout">
        <aside class="post-toc">
          <div class="post-toc-inner">
            <div class="toc-title">En este post</div>
            <ol>
              {
                headings.map((h, i) => (
                  <li>
                    <a href={`#h${i}`}>{h.text}</a>
                  </li>
                ))
              }
            </ol>
            <div class="toc-share">
              <div class="toc-share-title">Compartir</div>
              <div class="toc-share-row">
                <button class="toc-share-btn" data-copy-url>copy link</button>
                <a
                  class="toc-share-btn"
                  href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(post.title)}`}
                  target="_blank"
                  rel="noreferrer">𝕏</a
                >
                <a
                  class="toc-share-btn"
                  href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(`https://diegocabrera.dev/blog/${post.id}`)}`}
                  target="_blank"
                  rel="noreferrer">in</a
                >
              </div>
            </div>
          </div>
        </aside>

        <div class="post-main">
          <div class="tldr">
            <h4>TL;DR</h4>
            <p>{post.body.find((b) => b.type === "p")?.text}</p>
          </div>

          <div class="article-body">
            {
              (() => {
                let hIdx = 0;
                return post.body.map((b, i) => {
                  if (b.type === "p") return <p>{b.text}</p>;
                  if (b.type === "h2") {
                    const id = `h${hIdx}`;
                    hIdx++;
                    return <h2 id={id}>{b.text}</h2>;
                  }
                  if (b.type === "quote")
                    return <blockquote>"{b.text}"</blockquote>;
                  if (b.type === "code")
                    return (
                      <pre>
                        <code>{b.text}</code>
                      </pre>
                    );
                  return null;
                });
              })()
            }
          </div>

          <div class="post-author">
            <div class="post-author-avatar">
              <img
                src={avatarImage.src}
                alt="Avatar de Diego"
                class="post-author-photo"
                loading="eager"
              />
            </div>
            <div class="post-author-info">
              <div class="post-author-eyebrow">Escrito por</div>
              <div class="post-author-name">Diego Cabrera</div>
              <div class="post-author-role">
                Tech Lead · IA Aplicada · Bogotá
              </div>
              <div class="post-author-actions">
                <a
                  class="hero-social-btn"
                  href="https://www.linkedin.com/in/diego-andres-rojas/"
                  target="_blank"
                  rel="noreferrer"
                >
                  <Icon name="linkedin" />
                  <span>LinkedIn</span>
                </a>
                <a
                  class="hero-social-btn"
                  href="https://github.com/darcdev"
                  target="_blank"
                  rel="noreferrer"
                >
                  <Icon name="github" />
                  <span>GitHub</span>
                </a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <div class="post-more">
        <div class="eyebrow"><span class="idx">→</span> · Sigue leyendo</div>
        <h3
          class="sect-title"
          style="margin-top: 16px; font-size: clamp(28px, 3.4vw, 40px);"
        >
          Más del blog
        </h3>
        <div class="mag-bottom" style="margin-top: 36px;">
          {
            morePosts.map((p) => (
              <a
                href={`/blog/${p.id}`}
                class="mag-card mag-base"
                style="text-decoration: none; color: inherit;"
              >
                <div class="mag-cover">
                  <Cover kind={p.cover} label={p.category} />
                </div>
                <div class="mag-body">
                  <div class="mag-eyebrow">
                    <span>{p.category}</span>
                    <span>·</span>
                    <span>{p.date}</span>
                  </div>
                  <h3 class="mag-title">{p.title}</h3>
                  <p class="mag-excerpt-short">{p.excerpt}</p>
                  <div class="mag-foot">
                    <span class="mag-read">{p.readMin} min lectura →</span>
                  </div>
                </div>
              </a>
            ))
          }
        </div>
      </div>

      <div class="post-cta">
        <h3>¿Quieres construir algo similar?</h3>
        <p>Hablemos sobre tu próximo proyecto de IA aplicada.</p>
        <a href="/#contact" class="btn btn-primary">
          Contactar
          <Icon name="arrow" />
        </a>
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  document.querySelector("[data-copy-url]")?.addEventListener("click", () => {
    navigator.clipboard?.writeText(window.location.href);
  });
</script>
