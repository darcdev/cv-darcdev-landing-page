---
import Nav from "../components/islands/Nav";
import Footer from "../components/organisms/Footer.astro";
import WhatsAppFloat from "../components/atoms/WhatsAppFloat.astro";
import { defaultLocale } from "../i18n/config";
import { t } from "../i18n/translate";

interface Props {
  /** Active locale for this route. Defaults to the project default. */
  locale?: string;
  /** Nav item to highlight on standalone routes (e.g. blog archive/posts). */
  activeNav?: string;
  title?: string;
  description?: string;
  /** Translation key for <title>. Overrides `title` prop if provided. */
  titleKey?: string;
  /** Translation key for meta description. Overrides `description` prop if provided. */
  descriptionKey?: string;
}

function resolveActiveNav(pathname: string, explicit?: string): string | undefined {
  if (explicit) return explicit;
  if (/\/blog(\/|$)/.test(pathname)) return 'blog';
  return undefined;
}

const {
  locale = defaultLocale,
  activeNav: activeNavProp,
  title,
  description,
  titleKey = "meta.title",
  descriptionKey = "meta.description",
} = Astro.props;

const activeNav = resolveActiveNav(Astro.url.pathname, activeNavProp);

const renderedTitle = title ?? t(titleKey, undefined, locale);
const renderedDescription = description ?? t(descriptionKey, undefined, locale);
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={renderedDescription} />
    <meta name="generator" content={Astro.generator} />

    <meta property="og:title" content={renderedTitle} />
    <meta property="og:description" content={renderedDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={locale} />

    <link rel="icon" type="image/svg+xml" href="/favicon.png" />

    <title>{renderedTitle}</title>

    <script is:inline>
      (function () {
        const theme =
          localStorage.getItem("theme") ||
          (window.matchMedia("(prefers-color-scheme: dark)").matches
            ? "dark"
            : "light");
        document.documentElement.setAttribute("data-theme", theme);
      })();
    </script>
  </head>
  <body>
    <div class="app">
      <Nav locale={locale} activeNav={activeNav} client:load />
      <slot />
      <Footer locale={locale} />
      <WhatsAppFloat locale={locale} />
    </div>
  </body>
</html>

<style is:global>
  @import "../styles/global.css";
</style>
