---
import Icon from '../atoms/Icon.astro';
import { defaultLocale } from '../../i18n/config';
import { t } from '../../i18n/translate';
import { getCvHref } from '../../lib/cv';

interface Props {
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;
const cvHref = getCvHref(locale);
---

<div class="hero-social">
  <a class="hero-social-btn" href="https://github.com/darcdev" target="_blank" rel="noreferrer">
    <Icon name="github" />
    <span>GitHub</span>
    <span class="ext">↗</span>
  </a>
  <a class="hero-social-btn" href="https://www.linkedin.com/in/diego-andres-rojas/" target="_blank" rel="noreferrer">
    <Icon name="linkedin" />
    <span>LinkedIn</span>
    <span class="ext">↗</span>
  </a>
  <a
    class="hero-social-btn primary"
    href={cvHref}
    target="_blank"
    rel="noopener noreferrer"
  >
    <Icon name="download" />
    <span>{t('hero.social.cv', undefined, locale)}</span>
  </a>
</div>
