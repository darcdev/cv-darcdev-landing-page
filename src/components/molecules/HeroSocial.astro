---
import Icon from '../atoms/Icon.astro';
---

<div class="hero-social">
  <a class="hero-social-btn" href="https://github.com/diegocabrera" target="_blank" rel="noreferrer">
    <Icon name="github" />
    <span>GitHub</span>
    <span class="ext">↗</span>
  </a>
  <a class="hero-social-btn" href="https://linkedin.com/in/diego-cabrera" target="_blank" rel="noreferrer">
    <Icon name="linkedin" />
    <span>LinkedIn</span>
    <span class="ext">↗</span>
  </a>
  <a
    class="hero-social-btn primary"
    href="/cv/CV_Diego_Andres_Cabrera_Rojas_CV.pdf"
    download="Diego_Cabrera_CV.pdf"
  >
    <Icon name="download" />
    <span>Descargar CV</span>
  </a>
</div>
