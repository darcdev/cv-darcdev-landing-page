---
import Icon from '../atoms/Icon.astro';

interface Props {
  role: string;
  company: string;
  location: string;
  period: string;
  highlights: string[];
  current?: boolean;
  /** Optional index — kept for backwards compat; unused now. */
  index?: number;
}

const { role, company, location, period, highlights, current = false } = Astro.props;
---

<div class={`tl-item ${current ? 'now' : ''}`}>
  <div class="tl-marker" aria-hidden="true">
    <Icon name="briefcase" size={14} />
  </div>
  <div class="tl-head">
    <div class="tl-role">{role}</div>
    <div class="tl-period">{period}</div>
  </div>
  <div class="tl-company">{company} · <span>{location}</span></div>
  <ul class="tl-list">
    {highlights.map((h) => <li>{h}</li>)}
  </ul>
</div>
