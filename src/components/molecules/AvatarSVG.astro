---
import avatarImage from "../../assets/images/foto-perfil.png";
---

<div class="avatar-wrap">
  <div class="avatar-badge avatar-badge-1">
    <span class="dot"></span> ONLINE
  </div>
  <div class="avatar-badge avatar-badge-2">
    {"</>"} RAG · MCP
  </div>
  <div class="avatar-badge avatar-badge-3">AI · TECH LEAD</div>

  <img
    src={avatarImage.src}
    alt="Avatar de Diego"
    class="avatar-svg avatar-photo"
    loading="eager"
  />

  <div class="av-chip-photo">
    <span>{"{ai}"}</span>
  </div>
  <div class="av-orbit-photo"></div>
</div>

<style>
  /* Mobile-first: base styles for small screens */
  .avatar-photo {
    width: 80% !important;
    height: 80% !important;
    border-radius: 50%;
    object-fit: cover;
    object-position: center top;
    border: 2px solid var(--ink);
  }

  .av-chip-photo {
    position: absolute;
    top: 10%;
    right: 0;
    background: var(--ink);
    padding: 3px 6px;
    border-radius: 6px;
    font-family: "Geist Mono", monospace;
    font-size: 8px;
    color: var(--accent);
    animation: avChipPhotoFloat 4s ease-in-out infinite;
  }

  @keyframes avChipPhotoFloat {
    0%,
    100% {
      transform: rotate(-4deg);
    }
    50% {
      transform: translateY(-10px) rotate(4deg);
    }
  }

  .av-orbit-photo {
    position: absolute;
    bottom: 15%;
    left: 5%;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent);
    animation: avOrbitPhoto 6s linear infinite;
  }

  @keyframes avOrbitPhoto {
    0% {
      transform: rotate(0deg) translateX(20px) rotate(0deg);
    }
    100% {
      transform: rotate(360deg) translateX(20px) rotate(-360deg);
    }
  }

  /* 480px+: Larger phones */
  @media (min-width: 480px) {
    .av-chip-photo {
      padding: 4px 8px;
      font-size: 9px;
    }

    .av-orbit-photo {
      width: 10px;
      height: 10px;
    }
  }

  /* 768px+: Tablets and up - original styles */
  @media (min-width: 768px) {
    .avatar-photo {
      width: 85% !important;
      height: 85% !important;
    }

    .av-chip-photo {
      top: 15%;
      right: 5%;
      padding: 6px 12px;
      font-size: 11px;
    }

    .av-orbit-photo {
      bottom: 18%;
      left: 8%;
      width: 12px;
      height: 12px;
    }

    @keyframes avOrbitPhoto {
      0% {
        transform: rotate(0deg) translateX(30px) rotate(0deg);
      }
      100% {
        transform: rotate(360deg) translateX(30px) rotate(-360deg);
      }
    }
  }
</style>
