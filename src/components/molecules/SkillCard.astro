---
interface Props {
  group: string;
  items: string[];
  /** Optional index — kept for backwards compat; unused now (no more data-i18n markers). */
  index?: number;
}

const { group, items } = Astro.props;
---

<div class="skill-card">
  <h5>{group}</h5>
  <div class="skill-chips">
    {items.map((x) => <span class="skill-chip">{x}</span>)}
  </div>
</div>
