---
import StatCell from '../molecules/StatCell.astro';
import TimelineItem from '../molecules/TimelineItem.astro';
import SkillCard from '../molecules/SkillCard.astro';
import Reveal from '../islands/Reveal';
import { t } from '../../i18n/translate';
import { getProfile } from '../../data/profile';
import { getExperiences } from '../../data/experience';
import { getSkills } from '../../data/skills';
import { defaultLocale } from '../../i18n/config';

interface Props {
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;
const PROFILE = getProfile(locale);
const EXPERIENCE = getExperiences(locale);
const SKILLS = getSkills(locale);
---

<section id="about" class="section section-divider" data-screen-label="02 about">
  <div class="container">
    <Reveal client:visible>
      <div class="eyebrow">
        <span class="idx">02</span>
        <span> · {t('about.eyebrow', undefined, locale)}</span>
      </div>
      <h2 class="sect-title" style="margin-top: 18px;" set:html={t('about.title', undefined, locale)} />
    </Reveal>

    <div class="about-grid" style="margin-top: 56px;">
      <Reveal client:visible>
        <p class="bio-large" set:html={t('about.bio', undefined, locale)} />
      </Reveal>

      <Reveal client:visible delay={150}>
        <div class="about-card">
          <h4>{t('about.info.title', undefined, locale)}</h4>
          <div class="kv-list">
            <div class="row"><span class="k">{t('about.info.location', undefined, locale)}</span><span class="v">{PROFILE.location}</span></div>
            <div class="row"><span class="k">{t('about.info.email', undefined, locale)}</span><span class="v">{PROFILE.email}</span></div>
            <div class="row"><span class="k">{t('about.info.phone', undefined, locale)}</span><span class="v">{PROFILE.phone}</span></div>
            <div class="row"><span class="k">{t('about.info.languages', undefined, locale)}</span><span class="v">{t('about.info.languages.value', undefined, locale)}</span></div>
            <div class="row"><span class="k">{t('about.info.status', undefined, locale)}</span><span class="v" style="color: #2ea050;">{t('about.info.status.value', undefined, locale)}</span></div>
            <div class="row"><span class="k">{t('about.info.modality', undefined, locale)}</span><span class="v">{t('about.info.modality.value', undefined, locale)}</span></div>
          </div>
        </div>
      </Reveal>
    </div>

    <Reveal client:visible delay={200}>
      <div class="stats-grid">
        <StatCell number="7+"  labelKey="about.stats.years"    locale={locale} />
        <StatCell number={`${PROFILE.productionProjects}+`} labelKey="about.stats.projects" locale={locale} />
        <StatCell number={String(PROFILE.proceduresImplemented)} labelKey="about.stats.procedures" locale={locale} />
        <StatCell number={String(PROFILE.aiSolutionsInProduction)} labelKey="about.stats.ai" locale={locale} />
      </div>
    </Reveal>

    <Reveal client:visible>
      <div style="margin-top: 90px;">
        <div class="eyebrow">
          <span class="idx">02.1</span>
          <span> · {t('about.experience.eyebrow', undefined, locale)}</span>
        </div>
        <h3 class="sect-title" style="margin-top: 16px; font-size: clamp(28px, 3.4vw, 40px);" set:html={t('about.experience.title', undefined, locale)} />
      </div>
    </Reveal>

    <div class="timeline">
      {EXPERIENCE.map((e, i) => (
        <Reveal client:visible delay={i * 60}>
          <TimelineItem
            role={e.role}
            company={e.company}
            location={e.location}
            period={e.period}
            highlights={e.highlights}
            current={i === 0}
            index={i}
          />
        </Reveal>
      ))}
    </div>

    <Reveal client:visible>
      <div style="margin-top: 90px;">
        <div class="eyebrow">
          <span class="idx">02.2</span>
          <span> · {t('about.stack.eyebrow', undefined, locale)}</span>
        </div>
        <h3 class="sect-title" style="margin-top: 16px; font-size: clamp(28px, 3.4vw, 40px);">
          {t('about.stack.title', undefined, locale)}
        </h3>
      </div>
    </Reveal>

    <div class="skills-grid">
      {SKILLS.map((s, i) => (
        <Reveal client:visible delay={i * 50}>
          <SkillCard group={s.group} items={s.items} index={i} />
        </Reveal>
      ))}
    </div>
  </div>
</section>
