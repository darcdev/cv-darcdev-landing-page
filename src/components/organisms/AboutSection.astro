---
import StatCell from '../molecules/StatCell.astro';
import TimelineItem from '../molecules/TimelineItem.astro';
import SkillCard from '../molecules/SkillCard.astro';
import Reveal from '../islands/Reveal';
import { EXPERIENCE, SKILLS, PROFILE } from '../../data';
---

<section id="about" class="section section-divider" data-screen-label="02 about">
  <div class="container">
    <Reveal client:visible>
      <div class="eyebrow"><span class="idx">02</span> · Sobre mí</div>
      <h2 class="sect-title" style="margin-top: 18px;">
        Tech Lead que <span class="serif-it">codea</span>,<br/>
        arquitecto que <span class="serif-it">escucha</span>.
      </h2>
    </Reveal>

    <div class="about-grid" style="margin-top: 56px;">
      <Reveal client:visible>
        <p class="bio-large">
          Soy <strong>Diego Cabrera</strong>. He construido sistemas para entidades del Gobierno Colombiano, alcaldías y empresas privadas durante los últimos 7 años.
          <em> Mi día se reparte entre arquitectura, código hands-on y liderar equipos que aprenden a trabajar con agentes de IA.</em>
        </p>
      </Reveal>

      <Reveal client:visible delay={150}>
        <div class="about-card">
          <h4>Información</h4>
          <div class="kv-list">
            <div class="row"><span class="k">Ubicación</span><span class="v">{PROFILE.location}</span></div>
            <div class="row"><span class="k">Email</span><span class="v">{PROFILE.email}</span></div>
            <div class="row"><span class="k">Teléfono</span><span class="v">{PROFILE.phone}</span></div>
            <div class="row"><span class="k">Idiomas</span><span class="v">ES nativo · EN B1</span></div>
            <div class="row"><span class="k">Estado</span><span class="v" style="color: #2ea050;">● disponible</span></div>
            <div class="row"><span class="k">Modalidad</span><span class="v">remoto / híbrido</span></div>
          </div>
        </div>
      </Reveal>
    </div>

    <Reveal client:visible delay={200}>
      <div class="stats-grid">
        <StatCell number="7+" label="años experiencia" />
        <StatCell number="20+" label="proyectos en producción" />
        <StatCell number="5" label="trámites MinTIC liderados" />
        <StatCell number="∞" label="prompts iterados" mono />
      </div>
    </Reveal>

    <Reveal client:visible>
      <div style="margin-top: 90px;">
        <div class="eyebrow"><span class="idx">02.1</span> · Experiencia</div>
        <h3 class="sect-title" style="margin-top: 16px; font-size: clamp(28px, 3.4vw, 40px);">
          Una década escribiendo software<br/>que <span class="serif-it">importa</span>.
        </h3>
      </div>
    </Reveal>

    <div class="timeline">
      {EXPERIENCE.map((e, i) => (
        <Reveal client:visible delay={i * 60}>
          <TimelineItem
            role={e.role}
            company={e.company}
            location={e.location}
            period={e.period}
            highlights={e.highlights}
            current={i === 0}
          />
        </Reveal>
      ))}
    </div>

    <Reveal client:visible>
      <div style="margin-top: 90px;">
        <div class="eyebrow"><span class="idx">02.2</span> · Stack</div>
        <h3 class="sect-title" style="margin-top: 16px; font-size: clamp(28px, 3.4vw, 40px);">
          Herramientas que uso a diario.
        </h3>
      </div>
    </Reveal>

    <div class="skills-grid">
      {SKILLS.map((s, i) => (
        <Reveal client:visible delay={i * 50}>
          <SkillCard group={s.group} items={s.items} />
        </Reveal>
      ))}
    </div>
  </div>
</section>
