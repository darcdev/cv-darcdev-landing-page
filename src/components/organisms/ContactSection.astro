---
import Reveal from "../islands/Reveal";
import ContactLinks from "../islands/ContactLinks";
import StatusPill from "../atoms/StatusPill.astro";
import Icon from "../atoms/Icon.astro";
import { defaultLocale } from "../../i18n/config";
import { t } from "../../i18n/translate";

interface Props {
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;
---

<section
  id="contact"
  class="section section-divider"
  data-screen-label="06 contact"
>
  <div class="container">
    <Reveal client:visible>
      <div class="eyebrow">
        <span class="idx">06</span>
        <span> · {t('contact.eyebrow', undefined, locale)}</span>
      </div>
    </Reveal>
    <div class="contact-grid" style="margin-top: 30px;">
      <Reveal client:visible>
        <h2 class="contact-big" set:html={t('contact.title', undefined, locale)} />
        <p
          style="color: var(--muted); max-width: 460px; margin-top: 28px; font-size: 18px; line-height: 1.55;"
          set:html={t('contact.lede', undefined, locale)}
        />
        <div style="pill-contact">
          <StatusPill>
            <span>{t('contact.status', undefined, locale)}</span>
          </StatusPill>
          <a
            class="status-pill"
            href="/cv/CV_Diego_Andres_Cabrera_Rojas_CV.pdf"
            download="Diego_Cabrera_CV.pdf"
            style="cursor: pointer;"
          >
            <Icon name="download" size={14} />
            <span>{t('contact.cv', undefined, locale)}</span>
          </a>
        </div>
      </Reveal>

      <Reveal client:visible delay={150}>
        <ContactLinks locale={locale} client:visible />
      </Reveal>
    </div>
  </div>
</section>
