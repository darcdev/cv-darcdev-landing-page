---
import Reveal from '../islands/Reveal';
import AskAI from '../islands/AskAI';
import { defaultLocale } from '../../i18n/config';
import { t } from '../../i18n/translate';

interface Props {
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;
---

<section class="section section-divider">
  <div class="container">
    <Reveal client:visible>
      <div class="eyebrow">
        <span class="idx">04</span>
        <span> · {t('ask.eyebrow', undefined, locale)}</span>
      </div>
      <h2 class="sect-title" style="margin-top: 18px; margin-bottom: 36px;" set:html={t('ask.title', undefined, locale)} />
    </Reveal>
    <Reveal client:visible>
      <AskAI locale={locale} client:visible />
    </Reveal>
  </div>
</section>
