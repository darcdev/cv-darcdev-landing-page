---
import HeroShapes from '../molecules/HeroShapes.astro';
import AvatarSVG from '../molecules/AvatarSVG.astro';
import HeroSocial from '../molecules/HeroSocial.astro';
import StripMarquee from '../molecules/StripMarquee.astro';
import Button from '../atoms/Button.astro';
import StatusPill from '../atoms/StatusPill.astro';
import Icon from '../atoms/Icon.astro';
import DotGridBg from '../islands/DotGridBg';
import Terminal from '../islands/Terminal';
import { defaultLocale } from '../../i18n/config';
import { t } from '../../i18n/translate';

interface Props {
  locale?: string;
}

const { locale = defaultLocale } = Astro.props;
const homeHref = `/${locale}/#projects`;
const contactHref = `/${locale}/#contact`;
---

<section id="home" class="hero" data-screen-label="01 hero">
  <DotGridBg client:load />
  <HeroShapes />
  <div class="container">
    <div class="hero-grid">
      <div>
        <div class="eyebrow">
          <span class="idx">01</span>
          <span> · {t('hero.eyebrow', undefined, locale)}</span>
        </div>
        <h1 class="hero-headline" style="margin-top: 22px;" set:html={t('hero.headline', undefined, locale)} />
        <p class="hero-sub">
          {t('hero.sub', undefined, locale)}
        </p>
        <div class="hero-meta">
          <Button variant="primary" href={homeHref}>
            <span>{t('hero.cta.projects', undefined, locale)}</span>
            <Icon name="arrow" size={14} />
          </Button>
          <Button variant="outline" href={contactHref}>
            <span>{t('hero.cta.contact', undefined, locale)}</span>
          </Button>
          <StatusPill>
            <span>{t('hero.status', undefined, locale)}</span>
          </StatusPill>
        </div>
      </div>
      <div class="hero-side">
        <AvatarSVG />
        <HeroSocial locale={locale} />
      </div>
    </div>

    <Terminal locale={locale} client:visible />
  </div>
  <StripMarquee />
</section>
